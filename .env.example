# ─────────────────────────────────────────────────────────────
# ReconX - Environment Configuration
# Copy this file as .env and fill in your API keys
# All keys are OPTIONAL - tool works without them
# but having keys increases data coverage significantly
# ─────────────────────────────────────────────────────────────

# ── Certificate Transparency ──────────────────────────────────
# Certspotter - Higher rate limits with API key
# Get free key at: https://sslmate.com/certspotter/
CERTSPOTTER_API_KEY=

# ── Threat Intelligence ───────────────────────────────────────
# AlienVault OTX - Passive DNS & threat intelligence
# Get free key at: https://otx.alienvault.com/api
OTX_API_KEY=

# VirusTotal - Subdomain enumeration & file analysis
# Get free key at: https://www.virustotal.com/gui/my-apikey
VT_API_KEY=

# VirusTotal v2 - Domain siblings recursive enumeration
# Uses domain/report endpoint for domain_siblings discovery
# Can use the same key as VT_API_KEY above
VT_DOMAIN_API_KEY=

# ── Network Intelligence ──────────────────────────────────────
# Shodan - Internet-wide scanning data
# Get free key at: https://account.shodan.io/
SHODAN_API_KEY=

# Censys - Certificate & host search
# Get free keys at: https://search.censys.io/account/api
CENSYS_API_ID=
CENSYS_API_SECRET=

# ── DNS Intelligence ──────────────────────────────────────────
# SecurityTrails - Historical DNS records
# Get free key at: https://securitytrails.com/corp/api
SECURITYTRAILS_API_KEY=

# PassiveTotal (RiskIQ) - Passive DNS
# Get keys at: https://community.riskiq.com/
PASSIVETOTAL_USERNAME=
PASSIVETOTAL_API_KEY=

# ── Bug Bounty Platforms ──────────────────────────────────────
# BinaryEdge - Internet scanning data
# Get free key at: https://app.binaryedge.io/
BINARYEDGE_API_KEY=

# FullHunt - Attack surface data
# Get free key at: https://fullhunt.io/
FULLHUNT_API_KEY=

# ── Web Intelligence ──────────────────────────────────────────
# URLScan.io - Website scanning
# Get free key at: https://urlscan.io/user/signup
URLSCAN_API_KEY=

# ── Cyberspace Search Engines ─────────────────────────────────
# ProjectDiscovery Chaos - Subdomain dataset
# Get free key at: https://chaos.projectdiscovery.io/
CHAOS_API_KEY=

# FOFA - Chinese cyberspace search engine
# Get free key at: https://fofa.info/ (register + generate API key)
FOFA_EMAIL=
FOFA_API_KEY=

# ZoomEye - Cyberspace search engine
# Get free key at: https://www.zoomeye.hk/profile
ZOOMEYE_API_KEY=

# BuiltWith - Technology profiling
# Get key at: https://api.builtwith.com/
BUILTWITH_API_KEY=

# ── GitHub ────────────────────────────────────────────────────
# GitHub - Search code/repos for leaked credentials & subdomains
# Get token at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ── WordPress ─────────────────────────────────────────────────
# WPScan - WordPress vulnerability scanner API token
# Get free token at: https://wpscan.com/api
WPSCAN_API_TOKEN=
